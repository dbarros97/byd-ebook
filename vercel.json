{
  "rewrites": [
    { "source": "/pt", "destination": "/index.html" },
    { "source": "/en", "destination": "/index.html" }
  ],
  "redirects": [
    { "source": "/_files/:path*", "destination": "/", "statusCode": 308 }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" }
      ]
    }
  ]
}
